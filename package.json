{
  "name": "zaipex-acc",
  "version": "0.4.2",
  "description": "Agents Command Center — Orquestador ligero de agentes de IA para desarrollo en equipo",
  "homepage": "https://github.com/Zaipex-Labs/agent-control-center",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zaipex-Labs/agent-control-center.git"
  },
  "bugs": {
    "url": "https://github.com/Zaipex-Labs/agent-control-center/issues"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "agents",
    "orchestrator",
    "ai",
    "zaipex",
    "broker"
  ],
  "type": "module",
  "main": "dist/server/index.js",
  "bin": {
    "acc": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server/index.ts",
    "dev:cli": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "dashboard:dev": "vite",
    "dashboard:build": "vite build",
    "typecheck:dashboard": "tsc --noEmit -p tsconfig.dashboard.json",
    "lint": "eslint src tests scripts --max-warnings=99999",
    "deadcode": "knip --no-progress --no-exit-code",
    "prepublishOnly": "npm run build && npm run dashboard:build && npm test",
    "postbuild": "node -e \"import('node:fs').then(fs => fs.chmodSync('dist/cli/index.js', 0o755))\""
  },
  "author": "Zaipex Labs team",
  "contributors": [
    "Zaipex Labs team <hello@zaipex.ai>"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^11.9.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "ws": "^8.20.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.50",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "knip": "^6.12.2",
    "puppeteer": "^24.40.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20"
  }
}
